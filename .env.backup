# SQLx Configuration - Enable offline mode for compilation
SQLX_OFFLINE=true

# Database Configuration
DATABASE_URL=postgresql://root@localhost:26257/sirsi_nexus?sslmode=disable

# Runtime Environment
RUST_LOG=sirsi_core=debug,tower_http=debug

# AI Service Configuration
# OpenAI API Key for GPT models
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key for Claude models
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Redis Configuration for agent context store
REDIS_URL=redis://localhost:6379
